#### Moodle
```php
// moodle_plugin/edquest_import.php
defined('MOODLE_INTERNAL') || die();

class edquest_activity {
    public function import_questions($topic_data) {
        global $DB;
        
        // Criar atividade do tipo "Eduquest"
        $activity = new stdClass();
        $activity->course = $topic_data['course_id'];
        $activity->name = "Espanhol: " . $topic_data['topic_name'];
        $activity->intro = $topic_data['description'];
        $activity->timeopen = $topic_data['start_date'];
        $activity->timeclose = $topic_data['end_date'];
        $activity->grade = $topic_data['max_points'];
        
        // Importar questões com tags BNCC/LE
        foreach ($topic_data['questions'] as $q) {
            $question = new stdClass();
            $question->category = $topic_data['category_id'];
            $question->name = $q['id'];
            $question->questiontext = $q['stem'];
            $question->generalfeedback = $q['justification'];
            $question->defaultmark = $q['points'];
            $question->penalty = 0; // Sem penalidade para incentivar tentativa
            $question->qtype = $this->map_question_type($q['type']);
            
            // Tags para filtragem
            $question->tags = [
                'bncc:' . implode(',', $q['bncc_skills']),
                'level:' . $q['difficulty'],
                'topic:' . $topic_data['topic_id'],
                'language:spanish',
                'grade:7'
            ];
            
            $DB->insert_record('question', $question);
        }
        
        return $activity->id;
    }
}
```

