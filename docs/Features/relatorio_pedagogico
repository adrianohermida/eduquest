### 🔄 Geração Automática do Plano de Intervenção
```python
# services/intervention_planner.py
class InterventionPlanner:
    """Gera planos de intervenção personalizados baseados em dados de desempenho"""
    
    def generate_plan(self, student_id, class_id):
        # Coletar dados do aluno
        performance = self._get_student_performance(student_id, class_id)
        weaknesses = self._identify_weak_concepts(performance)
        
        # Gerar recomendações
        interventions = []
        for weakness in weaknesses:
            concept = weakness['concept']
            misconception = self._detect_misconception(weakness)
            
            # Selecionar recurso pedagógico adequado
            resource = self._select_intervention_resource(
                concept=concept,
                misconception=misconception,
                student_profile=performance['learning_style']
            )
            
            interventions.append({
                'concept': concept,
                'misconception': misconception,
                'intervention': {
                    'type': resource['type'],  # micro_lesson, discussion, flashcard_set
                    'resource_id': resource['id'],
                    'duration_minutes': resource['estimated_duration'],
                    'activity': resource['activity_description'],
                    'success_criteria': resource['success_metric']
                }
            })
        
        # Montar plano completo
        return {
            'student_id': student_id,
            'strengths': self._extract_strengths(performance),
            'weaknesses': interventions,
            'upcoming_srs_reviews': self._get_pending_srs(student_id),
            'personalized_tips': self._generate_tips(performance, interventions),
            'parent_communication': self._generate_parent_summary(performance, interventions)
        }
    
    def _detect_misconception(self, weakness_data):
        """Inferir concepção equivocada a partir de padrões de erro"""
        concept = weakness_data['concept']
        wrong_answers = weakness_data['common_wrong_answers']
        
        # Mapeamento de padrões de erro para misconceptions
        misconception_map = {
            'fatores_exodo_rural': {
                'seca_apenas': ['A', 'D'],  # Opções que mencionam apenas seca
                'ignora_mecanizacao': ['B', 'C']
            },
            'xenofobia_interna': {
                'restrito_estrangeiros': ['A', 'D'],
                'ignora_preconceito_regional': ['B', 'C']
            }
        }
        
        # Heurística simples: se maioria dos erros segue padrão X, inferir misconception X
        if concept in misconception_map:
            for misconception, error_patterns in misconception_map[concept].items():
                if any(ans in wrong_answers for ans in error_patterns):
                    return misconception
        
        return None  # Sem padrão claro identificado
```

