## 🚨 5.5 Alertas Automáticos para Queda de Desempenho ou Conceitos Críticos

### ⚙️ Sistema de Alertas em Tempo Real
```python
# services/alert_service.py
class AlertService:
    """Monitora métricas e dispara alertas pedagógicos automáticos"""
    
    CRITICAL_THRESHOLDS = {
        'overall_score_drop': -15,  # Queda de 15 pontos em 1 semana
        'concept_error_rate': 0.7,   # >70% de erro em um conceito
        'srs_reset_spike': 5,        # >5 questões resetadas em 24h
        'inactivity_days': 3         # 3 dias sem atividade
    }
    
    def check_and_trigger_alerts(self, student_id: str):
        """Verificar métricas e disparar alertas se necessário"""
        alerts = []
        
        # 1. Queda brusca de desempenho
        recent_scores = self._get_recent_scores(student_id, days=7)
        if self._detect_score_drop(recent_scores, threshold=self.CRITICAL_THRESHOLDS['overall_score_drop']):
            alerts.append(self._create_alert(
                type='score_drop',
                severity='high',
                message=f"Queda de {recent_scores['drop']} pontos na média em 7 dias",
                suggested_action="Agendar atendimento individual para diagnóstico"
            ))
        
        # 2. Conceito com taxa de erro crítica
        concept_errors = self._get_concept_error_rates(student_id)
        for concept, error_rate in concept_errors.items():
            if error_rate > self.CRITICAL_THRESHOLDS['concept_error_rate']:
                alerts.append(self._create_alert(
                    type='concept_critical',
                    severity='medium',
                    message=f"Conceito '{concept}' com {error_rate*100:.0f}% de erro",
                    suggested_action=f"Liberar micro-aula '{concept}_intervention'",
                    auto_action={'release_resource': f"ML_{concept.upper()}_01"}
                ))
        
        # 3. Pico de resets no SRS
        recent_resets = self._count_srs_resets(student_id, hours=24)
        if recent_resets > self.CRITICAL_THRESHOLDS['srs_reset_spike']:
            alerts.append(self._create_alert(
                type='srs_reset_spike',
                severity='medium',
                message=f"{recent_resets} questões resetadas nas últimas 24h",
                suggested_action="Revisar abordagem pedagógica para os conceitos afetados"
            ))
        
        # 4. Inatividade prolongada
        last_activity = self._get_last_activity(student_id)
        if last_activity and (datetime.now() - last_activity).days > self.CRITICAL_THRESHOLDS['inactivity_days']:
            alerts.append(self._create_alert(
                type='inactivity',
                severity='low',
                message=f"Sem atividade há {(datetime.now() - last_activity).days} dias",
                suggested_action="Enviar mensagem de incentivo via app ou e-mail"
            ))
        
        # Enviar alertas para o professor
        if alerts:
            self._notify_teacher(student_id, alerts)
            # Opcional: notificar coordenador se severity='high'
            if any(a['severity'] == 'high' for a in alerts):
                self._notify_coordinator(student_id, alerts)
        
        return alerts
```

### 📱 Interface de Alertas no Dashboard do Professor
```jsx
// components/AlertPanel.jsx
const AlertPanel = ({ alerts, onAcknowledge, onTakeAction }) => {
  const getAlertIcon = (severity) => {
    switch(severity) {
      case 'high': return '🚨';
      case 'medium': return '⚠️';
      case 'low': return 'ℹ️';
      default: return '🔔';
    }
  };
  
  return (
    <div className="alert-panel">
      <h3>🔔 Alertas Pedagógicos</h3>
      {alerts.length === 0 ? (
        <p className="no-alerts">✅ Tudo em ordem! Nenhum alerta ativo.</p>
      ) : (
        <ul className="alert-list">
          {alerts.map(alert => (
            <li key={alert.id} className={`alert-item alert-${alert.severity}`}>
              <div className="alert-header">
                <span className="alert-icon">{getAlertIcon(alert.severity)}</span>
                <span className="alert-type">{alert.type}</span>
                <span className="alert-time">{formatTimeAgo(alert.created_at)}</span>
              </div>
              <p className="alert-message">{alert.message}</p>
              <div className="alert-actions">
                <button 
                  className="btn-action"
                  onClick={() => onTakeAction(alert.suggested_action)}
                >
                  {alert.auto_action ? '⚡ Ação Automática' : '🔧 Intervir'}
                </button>
                <button 
                  className="btn-dismiss"
                  onClick={() => onAcknowledge(alert.id)}
                >
                  ✓ Reconhecer
                </button>
              </div>
            </li>
          ))}
        </ul>
      )}
    </div>
  );
};
