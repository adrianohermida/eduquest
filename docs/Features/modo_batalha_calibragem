### 🔥 Sistema de Streaks (Motivação por Dopamina)
```javascript
// streakManager.js
class StreakManager {
  constructor(studentId) {
    this.studentId = studentId;
    this.currentStreak = 0;
    this.bestStreak = 0;
    this.lastAnswerTimestamp = null;
  }

  recordAnswer(isCorrect, responseTimeMs) {
    const now = Date.now();
    
    // Reset streak se > 24h sem atividade
    if (this.lastAnswerTimestamp && (now - this.lastAnswerTimestamp) > 86400000) {
      this.currentStreak = 0;
    }
    
    if (isCorrect) {
      this.currentStreak++;
      this.bestStreak = Math.max(this.bestStreak, this.currentStreak);
      
      // Gatilhos emocionais por marco
      if ([3, 5, 10, 20].includes(this.currentStreak)) {
        triggerCelebration(this.currentStreak);
        awardBadge(`streak_${this.currentStreak}`);
      }
    } else {
      this.currentStreak = 0;
      triggerEncouragement(); // "Quase! Vamos tentar de novo?"
    }
    
    this.lastAnswerTimestamp = now;
    return this.calculatePoints(isCorrect, responseTimeMs);
  }

  calculatePoints(isCorrect, responseTimeMs) {
    let basePoints = this.getBasePointsForLevel();
    let multiplier = 1.0;
    
    // Aplicar multiplicador de streak
    if (this.currentStreak >= 10) multiplier = 1.5;
    else if (this.currentStreak >= 5) multiplier = 1.25;
    else if (this.currentStreak >= 3) multiplier = 1.1;
    
    // Bônus de tempo (responder rápido com acerto)
    if (isCorrect && responseTimeMs < this.getTimeLimit() * 0.5) {
      basePoints += Math.floor(basePoints * 0.2);
    }
    
    return isCorrect ? Math.floor(basePoints * multiplier) : 0;
  }
}
```

