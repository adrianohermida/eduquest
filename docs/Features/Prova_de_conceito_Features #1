## 🗄️ 1.3 Estrutura do Banco de Dados (SQL Schema)

```sql
-- Tabela principal de questões
CREATE TABLE questions (
    id UUID PRIMARY KEY DEFAULT gen_random_uuid(),
    question_id VARCHAR(50) UNIQUE NOT NULL,
    chapter INTEGER CHECK (chapter IN (6, 7)),
    topic_id INTEGER CHECK (topic_id BETWEEN 1 AND 9),
    difficulty_level VARCHAR(4) CHECK (difficulty_level IN ('N1', 'N2', 'N3', 'ELIM')),
    question_type VARCHAR(10) CHECK (question_type IN ('MC', 'VF', 'DISS', 'ELIM')),
    
    -- Conteúdo
    stem TEXT NOT NULL,
    options JSONB,
    correct_answer VARCHAR(10),
    justification TEXT,
    tip_text TEXT,
    tip_icon VARCHAR(10),
    tip_audio_file VARCHAR(100),
    
    -- Classificação pedagógica
    bncc_skills TEXT[],
    cognitive_skills TEXT[],
    emotional_triggers TEXT[],
    concept_cluster VARCHAR(50),
    
    -- Configurações de sistema
    spaced_repetition_enabled BOOLEAN DEFAULT true,
    sr_intervals INTEGER[] DEFAULT '{3600,86400,259200,604800,1296000}',
    battle_unlock_score INTEGER DEFAULT 85,
    points_value INTEGER DEFAULT 10,
    
    -- Metadados
    status VARCHAR(20) DEFAULT 'draft',
    created_at TIMESTAMPTZ DEFAULT NOW(),
    updated_at TIMESTAMPTZ DEFAULT NOW(),
    
    -- Índices para performance
    INDEX idx_chapter_topic (chapter, topic_id),
    INDEX idx_difficulty (difficulty_level),
    INDEX idx_bncc (bncc_skills),
    INDEX idx_concept (concept_cluster)
);

-- Tabela de acompanhamento do aluno por questão
CREATE TABLE student_question_progress (
    id UUID PRIMARY KEY DEFAULT gen_random_uuid(),
    student_id UUID NOT NULL,
    question_id UUID REFERENCES questions(id),
    
    -- Progresso de repetição espaçada
    sr_current_stage INTEGER DEFAULT 0,
    sr_next_review_at TIMESTAMPTZ,
    sr_consolidated BOOLEAN DEFAULT false,
    
    -- Histórico de respostas
    total_attempts INTEGER DEFAULT 0,
    correct_attempts INTEGER DEFAULT 0,
    last_answered_at TIMESTAMPTZ,
    last_was_correct BOOLEAN,
    
    -- Metadados de desempenho
    avg_response_time_seconds DECIMAL(5,2),
    hints_used_count INTEGER DEFAULT 0,
    
    UNIQUE(student_id, question_id),
    INDEX idx_student_reviews (student_id, sr_next_review_at),
    INDEX idx_due_for_review (sr_next_review_at) WHERE sr_consolidated = false
);
```

