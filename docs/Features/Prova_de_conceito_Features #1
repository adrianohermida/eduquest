```

### Script Python de Importação
```python
# scripts/import_questions.py
import csv
import json
import psycopg2
from datetime import datetime
from validators.question_schema import validate_question

def import_questions_from_csv(csv_path: str, db_config: dict):
    conn = psycopg2.connect(**db_config)
    cursor = conn.cursor()
    
    with open(csv_path, 'r', encoding='utf-8') as f:
        reader = csv.DictReader(f)
        
        for row in reader:
            # Construir JSON da questão
            question = {
                "meta": {
                    "question_id": row['question_id'],
                    "status": "published",
                    "created_at": datetime.utcnow().isoformat()
                },
                "content": {
                    "stem": row['stem'],
                    "type": "multiple_choice" if row['question_type'] == 'MC' else row['question_type'],
                    "options": json.loads(row['options_json']),
                    "correct_answer": row['correct_answer'],
                    "justification": row['justification'],
                    "tip": {
                        "text": row['tip_text'],
                        "icon": row['tip_icon']
                    }
                },
                "classification": {
                    "chapter": int(row['chapter']),
                    "topic_id": int(row['topic_id']),
                    "difficulty_level": row['difficulty'],
                    "question_type": row['question_type'],
                    "cognitive_skills": json.loads(row['cognitive_skills'])
                },
                "bncc": {
                    "skills": json.loads(row['bncc_skills'])
                },
                "spaced_repetition": {"enabled": True},
                "battle_mode": {"min_score_to_unlock_next": 85 if row['difficulty'] == 'N1' else 80}
            }
            
            # Validar schema
            if not validate_question(question):
                print(f"❌ Questão {row['question_id']} inválida - pulando")
                continue
            
            # Inserir no banco
            cursor.execute("""
                INSERT INTO questions (
                    question_id, chapter, topic_id, difficulty_level, question_type,
                    stem, options, correct_answer, justification, tip_text, tip_icon,
                    bncc_skills, cognitive_skills, spaced_repetition_enabled,
                    battle_unlock_score, status
                ) VALUES (%s, %s, %s, %s, %s, %s, %s, %s, %s, %s, %s, %s, %s, %s, %s, %s)
                ON CONFLICT (question_id) DO UPDATE SET
                    updated_at = NOW(),
                    stem = EXCLUDED.stem,
                    options = EXCLUDED.options
            """, (
                row['question_id'], row['chapter'], row['topic_id'], row['difficulty'],
                row['question_type'], row['stem'], row['options_json'],
                row['correct_answer'], row['justification'], row['tip_text'],
                row['tip_icon'], json.loads(row['bncc_skills']),
                json.loads(row['cognitive_skills']), True,
                85 if row['difficulty'] == 'N1' else 80, 'published'
            ))
    
    conn.commit()
    cursor.close()
    conn.close()
    print(f"✅ Importação concluída: {reader.line_num - 1} questões processadas")
```

